{
    "[yaml]": {
        "diffEditor.ignoreTrimWhitespace": true
    },
    "catppuccin.boldKeywords": false,
    "catppuccin.bracketMode": "monochromatic",
    "catppuccin.italicComments": false,
    "catppuccin.italicKeywords": false,
    "catppuccin.workbenchMode": "minimal",
    "chat.commandCenter.enabled": false,
    "chat.editor.fontFamily": "Fira Code",
    "chat.editor.fontSize": 13,
    "debug.console.fontFamily": "Fira Code",
    "debug.toolBarLocation": "commandCenter",
    "diffEditor.codeLens": true,
    "diffEditor.hideUnchangedRegions.enabled": true,
    "diffEditor.ignoreTrimWhitespace": true,
    "diffEditor.renderSideBySide": false,
    "editor.codeLensFontFamily": "Fira Code",
    "editor.foldingHighlight": false,
    "editor.fontFamily": "Fira Code",
    "editor.fontLigatures": true,
    "editor.fontSize": 13,
    "editor.inlayHints.fontFamily": "Fira Code",
    "editor.inlineSuggest.fontFamily": "Fira Code",
    "editor.minimap.enabled": false,
    "editor.semanticHighlighting.enabled": true,
    "files.associations": {
        ".env*": "properties"
    },
    "files.exclude": {
        "**/.git": false
    },
    "git.confirmSync": false,
    "git.openRepositoryInParentFolders": "never",
    "git.replaceTagsWhenPull": true,
    "go.coverageOptions": "showCoveredCodeOnly",
    "go.coverOnTestPackage": false,
    "go.diagnostic.vulncheck": "Imports",
    "go.testExplorer.packageDisplayMode": "nested",
    "go.testFlags": [
        "-race",
        "-count=1",
    ],
    "go.testTimeout": "15s",
    "go.toolsManagement.autoUpdate": true,
    "gopls": {
        "ui.semanticTokens": true
    },
    "markdown.preview.fontFamily": "Fira Code",
    "markdown.preview.fontSize": 13,
    "notebook.output.fontFamily": "Fira Code",
    "redhat.telemetry.enabled": false,
    "scm.defaultViewMode": "tree",
    "scm.diffDecorationsIgnoreTrimWhitespace": "inherit",
    "scm.inputFontFamily": "Fira Code",
    "scm.repositories.visible": 0,
    "search.defaultViewMode": "tree",
    "security.workspace.trust.enabled": false,
    "terminal.explorerKind": "both",
    "terminal.external.osxExec": "iTerm.app",
    "terminal.integrated.defaultProfile.osx": "fish",
    "terminal.integrated.fontFamily": "Fira Code",
    "terminal.integrated.minimumContrastRatio": 1,
    "terminal.integrated.stickyScroll.enabled": false,
    "window.newWindowDimensions": "maximized",
    "window.titleBarStyle": "custom",
    "workbench.list.multiSelectModifier": "alt",
    "workbench.startupEditor": "none",
    "workbench.colorTheme": "Catppuccin Mocha",
    "workbench.iconTheme": "catppuccin-mocha",
    "catppuccin.accentColor": "lavender"
}